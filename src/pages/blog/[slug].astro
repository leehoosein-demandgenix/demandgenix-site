---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getAllBlogPosts, getBlogPostBySlug } from '../../lib/sanity.js';
import { formatDate, getCategoryColor, getCategoryLabel, blocksToHtml, processListItems } from '../../lib/blogHelpers.js';
import { optimizeSanityImage } from '../../lib/imageHelpers.js';

export async function getStaticPaths() {
  const posts = await getAllBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.slug.current },
    props: { post },
  }));
}

const { slug } = Astro.params;
let post;

try {
  post = await getBlogPostBySlug(slug);
} catch (error) {
  console.error('Error fetching blog post:', error);
}

if (!post) {
  return Astro.redirect('/404');
}

// Process content with list wrapping
let contentHtml = blocksToHtml(post.content);
console.log('Before processListItems - contains blog-list-item:', contentHtml.includes('blog-list-item'));
contentHtml = processListItems(contentHtml);
console.log('After processListItems - contains <ul>:', contentHtml.includes('<ul'));

// AEO schema: scoped to this specific blog post only
const AEO_SLUG = 'demand-gen-vs-lead-gen-which-should-your-lean-team-prioritise-right-now';
const isAeoPost = slug === AEO_SLUG;

if (isAeoPost) {
  // Inject id="faq-section" onto the FAQ heading so the Speakable cssSelector can reference it
  contentHtml = contentHtml.replace(
    /(<h2)( [^>]*>|>)([\s\S]*?(?:FAQ|Frequently Asked)[\s\S]*?)(<\/h2>)/i,
    '$1 id="faq-section"$2$3$4'
  );
}

const aeoHowToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to transition from a lead-gen-only model to a demand-gen model on a budget",
  "description": "A three-phase approach for lean B2B teams to introduce demand generation alongside existing lead gen activity, without pausing current pipeline activity.",
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Review your existing content",
      "text": "Identify gated content that proves your value proposition or speaks to your audience's pain points and ungate it. Make it accessible to your ICP, promote it on your website, allow search engines and LLMs to crawl it, and create long-form social posts to distribute it. This should take approximately one week, with early engagement signals visible within the first few weeks."
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Create co-partnered content",
      "text": "Identify a partner whose audience overlaps with your ICP. Find a shared pain point and create a how-to webinar you can both promote. This broadens your engaged audience and deepens the partner relationship. Allow approximately four weeks to plan and host, and ask your partner to lead on infrastructure if they have an established audience."
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Take dark social seriously",
      "text": "Find the Slack groups, closed forums and Reddit communities where your ICP discusses their problems. Engage authentically and add value without being overly promotional. Start with one channel and build consistent engagement over time. Pipeline quality improvements should become visible within the same quarter."
    }
  ]
};

const aeoBlogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "Demand Gen vs. Lead Gen: Which Should Your Lean Team Prioritise Right Now?",
  "description": "A practical guide for lean B2B marketing teams on the core differences between demand generation and lead generation, which to prioritise at each growth stage, and how to transition from a lead-gen-only model on a budget.",
  "url": "https://demandgenix.uk/blog/demand-gen-vs-lead-gen-which-should-your-lean-team-prioritise-right-now/",
  "datePublished": "2026-02-23T00:00:00+00:00",
  "author": {
    "@type": "Person",
    "name": "Lee Hoosein",
    "url": "https://www.linkedin.com/in/lee-hoosein/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "DemandGenix",
    "url": "https://demandgenix.uk",
    "logo": {
      "@type": "ImageObject",
      "url": "https://demandgenix.uk/favicon.ico"
    }
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": [".callout-box", "#faq-section"]
  }
};

// Ensure date strings include timezone so schema.org validators accept them
const toIsoDateTime = (date: string) => date?.includes('T') ? date : `${date}T00:00:00+00:00`;

// Dynamic FAQPage schema — driven by post.faqs from Sanity
const faqSchema = post.faqs?.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": post.faqs.map((faq: { question: string; answer: string }) => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    }
  : null;

// Create blog-specific structured data
const SITE_URL = "https://demandgenix.uk";
const blogStructuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.excerpt,
  "image": post.heroImage ? `${post.heroImage.url}` : `${SITE_URL}/og-image.jpg`,
  "author": {
    "@type": "Person",
    "name": post.author,
    "url": "https://www.linkedin.com/in/lee-hoosein/",
    "sameAs": ["https://www.linkedin.com/in/lee-hoosein/"]
  },
  "publisher": {
    "@type": "Organization",
    "name": "DemandGenix Limited",
    "logo": {
      "@type": "ImageObject",
      "url": `${SITE_URL}/favicon.svg`
    }
  },
  "datePublished": toIsoDateTime(post.publishDate),
  "dateModified": toIsoDateTime(post.publishDate),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${SITE_URL}/blog/${post.slug.current}/`
  },
  "articleSection": getCategoryLabel(post.category),
  "keywords": post.tags || [],
  "inLanguage": "en-GB"
};

---

<Layout 
  title={post.metaTitle || `${post.title} | DemandGenix Blog`}
  description={post.metaDescription || post.excerpt}
>
  <!-- Add blog-specific structured data -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(blogStructuredData)}></script>
  {faqSchema && (
    <script type="application/ld+json" slot="head" is:inline set:html={JSON.stringify(faqSchema)}></script>
  )}
  <!-- AEO schema blocks: HowTo, BlogPosting+Speakable — this post only -->
  {isAeoPost && (
    <Fragment slot="head">
      <script type="application/ld+json" is:inline set:html={JSON.stringify(aeoHowToSchema)}></script>
      <script type="application/ld+json" is:inline set:html={JSON.stringify(aeoBlogPostingSchema)}></script>
    </Fragment>
  )}
<style>
  /* Enhanced list styling */
  article :global(ul:not(nav ul)) {
    list-style-type: disc;
    list-style-position: outside;
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  article :global(ol:not(nav ol)) {
    list-style-type: decimal;
    list-style-position: outside;
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  article :global(li:not(nav li)) {
    margin-bottom: 0.75rem;
    padding-left: 0.5rem;
    line-height: 1.75;
  }

  article :global(h3 + ul),
  article :global(h3 + ol) {
    margin-top: 1rem;
  }

  /* Code block styling - Full blocks */
  article :global(pre) {
    background-color: #1f2937;
    border-radius: 0.5rem;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
    border: 1px solid #374151;
  }

  article :global(pre code) {
    color: #f3f4f6;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 0.875rem;
    line-height: 1.7;
    display: block;
  }

  /* Inline code styling */
  article :global(p code:not(pre code)),
  article :global(li code:not(pre code)),
  article :global(h1 code:not(pre code)),
  article :global(h2 code:not(pre code)),
  article :global(h3 code:not(pre code)),
  article :global(h4 code:not(pre code)) {
    background-color: #f3f4f6;
    color: #1f2937;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    border: 1px solid #e5e7eb;
  }

  /* Comparison table — ensure responsive scroll on mobile */
  article :global(.overflow-x-auto) {
    -webkit-overflow-scrolling: touch;
  }

  article :global(table) {
    min-width: 480px;
  }

  /* Callout box spacing */
  article :global(.callout-box + .callout-box) {
    margin-top: 1rem;
  }

  /* Breadcrumb specific styles to prevent list styling */
  nav :global(ol),
  nav :global(ul) {
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  nav :global(li) {
    display: inline !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  nav :global(li::before) {
    content: none !important;
  }
  /* Fix bullet alignment to match paragraph text */
article :global(ul) {
  list-style-type: disc;
  list-style-position: outside;
  margin-left: 1.5rem;
  padding-left: 0;
  margin-bottom: 1.5rem;
}

article :global(ul li) {
  margin-bottom: 0.75rem;
  padding-left: 0.5rem;
  line-height: 1.75;
}
</style>
  <Header />
  
  <main>
    <!-- Blog Post Hero -->
    <article class="py-16 lg:py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav class="mb-8">
          <ol class="flex items-center space-x-2 text-sm text-gray-500">
            <li><a href="/" class="hover:text-gray-700">Home</a></li>
            <li>→</li>
            <li><a href="/blog/" class="hover:text-gray-700">Blog</a></li>
            <li>→</li>
            <li class="text-gray-900 truncate">{post.title}</li>
          </ol>
        </nav>

        <!-- Post Header -->
        <header class="mb-8">
          <div class="flex items-center gap-4 mb-4">
            <span class={`px-3 py-1 text-sm font-medium rounded-full ${getCategoryColor(post.category)}`}>
              {getCategoryLabel(post.category)}
            </span>
            <span class="text-sm text-gray-500">
              {formatDate(post.publishDate)}
            </span>
            {post.readingTime && (
              <span class="text-sm text-gray-500">
                {post.readingTime} min read
              </span>
            )}
          </div>
          
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
            {post.title}
          </h1>
          
          <p class="text-xl text-gray-600 leading-relaxed">
            {post.excerpt}
          </p>
          
          <div class="flex items-center mt-6 pt-6 border-t border-gray-200">
            <div class="flex items-center">
              <div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center">
                <span class="text-primary-600 font-medium">
                  {post.author.charAt(0)}
                </span>
              </div>
              <div class="ml-3">
                <a href="https://www.linkedin.com/in/lee-hoosein/" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-gray-900 hover:text-primary-600 transition-colors">
                  {post.author}
                </a>
                <p class="text-sm text-gray-500">
                  Founder, DemandGenix
                </p>
              </div>
            </div>
          </div>
        </header>

        <!-- Hero Image -->
        {post.heroImage && (
          <div class="mb-12">
            <img 
              src={optimizeSanityImage(post.heroImage.url, { 
                width: 1200, 
                height: 675, 
                fit: 'max' 
              })}
              alt={post.heroImage.alt}
              width="1200"
              height="675"
              loading="eager"
              decoding="async"
              class="w-full rounded-lg shadow-lg"
            />
          </div>
        )}

        <!-- Post Content -->
        <div class="prose prose-lg max-w-none">
          <div set:html={contentHtml}></div>
        </div>

        <!-- Post Footer -->
        <footer class="mt-12 pt-8 border-t border-gray-200">
          <div class="flex items-center justify-between">
            <div>
              {post.tags && post.tags.length > 0 && (
                <div>
                  <span class="text-sm font-medium text-gray-900 mr-2">Tags:</span>
                  {post.tags.map((tag, index) => (
                    <span class="text-sm text-primary-600 mr-2">
                      #{tag}{index < post.tags.length - 1 && ','}
                    </span>
                  ))}
                </div>
              )}
            </div>
            <a 
              href="/blog/" 
              class="text-primary-600 hover:text-primary-700 font-medium text-sm"
            >
              ← Back to Blog
            </a>
          </div>
        </footer>

        <!-- CTA Section -->
        <section class="mt-16 bg-gray-50 rounded-lg p-8 text-center">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">
            Stop Guessing. Start Growing.
          </h3>
          <p class="text-gray-600 mb-6">
            Skip the sales team. Book a 30-minute diagnostic call directly with a senior strategist to identify your growth blockers.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a 
              href="/contact/" 
              class="bg-secondary-600 text-white px-6 py-3 rounded-lg hover:bg-secondary-700 transition-colors"
            >
              Book a Strategy Review
            </a>
            <a 
              href="/blog/" 
              class="border border-gray-300 text-gray-700 px-6 py-3 rounded-lg hover:bg-gray-50 transition-colors"
            >
              Read More Articles
            </a>
          </div>
        </section>
      </div>
    </article>
  </main>

  <Footer />
</Layout>